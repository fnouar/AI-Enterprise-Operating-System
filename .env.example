# AI-EOS Environment

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_eos
POSTGRES_USER=ai_eos
POSTGRES_PASSWORD=ai_eos_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Temporal
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233

# Keycloak
KEYCLOAK_URL=http://keycloak:8080/auth
KEYCLOAK_REALM=ai-eos
KEYCLOAK_CLIENT_ID=ai-eos-client

# Application
SPRING_PROFILES_ACTIVE=local
LOG_LEVEL_ROOT=INFO
